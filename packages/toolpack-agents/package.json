{
  "name": "@toolpack-sdk/agents",
  "version": "1.3.0",
  "description": "Agent layer for the Toolpack SDK - build, compose, and deploy AI agents with a consistent, extensible pattern",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "exports": {
    "types": "./dist/index.d.ts",
    "import": "./dist/index.js",
    "require": "./dist/index.cjs"
  },
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "build:dev": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "watch": "tsup --watch",
    "lint": "eslint src/**",
    "publish:npm": "npm run build && npm run test && npm publish --access public"
  },
  "keywords": [
    "ai",
    "llm",
    "agent",
    "ai-agent",
    "slack",
    "telegram",
    "webhook",
    "cron",
    "scheduler",
    "typescript",
    "sdk",
    "toolpack"
  ],
  "author": "Sajeer (https://sajeerzeji.com)",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/toolpack-ai/toolpack-sdk.git"
  },
  "homepage": "https://toolpacksdk.com",
  "bugs": {
    "url": "https://github.com/toolpack-ai/toolpack-sdk/issues"
  },
  "peerDependencies": {
    "toolpack-sdk": "^1.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
